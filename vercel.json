{
  "version": 2,
  "builds": [
    {
      "src": "backend/index.html",
      "use": "@vercel/static"
    },
    {
      "src": "api/app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/.*",
      "dest": "/api/app.py"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/.*",
      "dest": "/backend/index.html"
    }
  ]
}